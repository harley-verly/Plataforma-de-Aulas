{
  "name": "plataforma-de-aulas",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "node scripts/run-workspace-sequence.mjs build",
    "build:packages": "node scripts/run-workspace-sequence.mjs build:packages",
    "dev": "node scripts/run-pnpm.mjs -r --parallel --filter @plataforma/contracts --filter @plataforma/config --filter @plataforma/ui --filter @plataforma/api --filter @plataforma/web dev",
    "typecheck": "node scripts/run-workspace-sequence.mjs typecheck",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "prisma": "^6.8.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
